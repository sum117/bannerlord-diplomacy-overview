<!--
  Relations tab panel (issue #6): the kingdom war web.

  The UIExtenderEx insert node applies DataSource="{Relations}" plus the vanilla panel margins to
  this prefab's root widget, so every binding in this file resolves against RelationsVM — the root's
  IsVisible="@IsSelected" is the exact vanilla panel idiom (ArmiesPanel root binds IsVisible="@Show"
  against its DataSource="{Army}" scope). Prefab file name = XML element name (global namespace, P-11).

  Layout: a fixed 1400x800 design-space canvas centered in the panel; only the canvas size is a
  constant here (kept in sync with RelationsVM). Everything density-dependent — node box and banner
  dimensions, label visibility, edge endpoints/thickness — is BOUND from the VM, computed per
  rebuild by Core's WebDensity: real modded campaigns hold 80+ living kingdoms (docs/research/10
  run 7, P-24), where fixed vanilla-count sizing fuses the web into a solid ring.

  Collection binding is the nameplate/map-trackers idiom (vanilla MapTrackers.xml): a plain
  stretched Widget with DataSource="{List}" + ItemTemplate creates one free-positioned child per
  item. Edges render BEFORE nodes so the lines pass under the medallions.
-->
<Prefab>
  <Constants>
    <Constant Name="Canvas.Width" Value="1400" />
    <Constant Name="Canvas.Height" Value="800" />

    <Constant Name="NodeLabel.MarginTop" Value="90" />
  </Constants>
  <Window>
    <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" IsVisible="@IsSelected">
      <Children>

        <!-- Transparent event guard: reveals the vanilla kingdom-screen gaussian blur behind the
             panel (we paint no opaque fill of our own) while still catching clicks so they do not
             fall through to whatever sits beneath the screen. -->
        <Widget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" />

        <!-- No panel title: the vanilla kingdom screen already shows the kingdom name centered at
             the top, and the active tab reads "Relations" — matching the design reference, which
             gives the top-left corner to the legend. -->

        <!-- Design-space canvas -->
        <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="!Canvas.Width" SuggestedHeight="!Canvas.Height" HorizontalAlignment="Center" VerticalAlignment="Center">
          <Children>

            <!-- Edges (under the nodes): one self-drawing widget per war line -->
            <Widget DataSource="{Edges}" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" DoNotAcceptEvents="true">
              <ItemTemplate>
                <DiplomacyOverviewEdgeWidget WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" DoNotAcceptEvents="true" X1="@X1" Y1="@Y1" X2="@X2" Y2="@Y2" ApexX="@ApexX" ApexY="@ApexY" LineColor="@LineColor" LineThickness="@LineThickness" />
              </ItemTemplate>
            </Widget>

            <!-- Nodes (over the edges): banner medallion + optional name label, freely positioned;
                 all dimensions arrive density-scaled from RelationNodeVM. The item root is a
                 brushless ButtonWidget: clicking anywhere in the node box opens the faction's
                 encyclopedia page (#10) -->
            <Widget DataSource="{Nodes}" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" DoNotAcceptEvents="true">
              <ItemTemplate>
                <ButtonWidget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="@BoxWidth" SuggestedHeight="@BoxHeight" HorizontalAlignment="Left" VerticalAlignment="Top" PositionXOffset="@X" PositionYOffset="@Y" DoNotPassEventsToChildren="true" Command.Click="ExecuteOpenEncyclopedia">
                  <Children>
                    <!-- Sizing wrapper: binds the density-scaled banner dims in the NODE's scope,
                         because the masked widget itself re-scopes onto {Banner} where those
                         properties do not exist. CircularClipEnabled + IsCircularClipRadiusHalfOfWidth
                         clip the banner to a circle (radius = half the box width) at render time —
                         the vanilla Widget mechanism (SetCircualMask), no custom sprite — giving the
                         reference's circular sigil medallions. -->
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="@BannerWidth" SuggestedHeight="@BannerHeight" HorizontalAlignment="Center" VerticalAlignment="Top" DoNotAcceptEvents="true" CircularClipEnabled="true" IsCircularClipRadiusHalfOfWidth="true">
                      <Children>
                        <MaskedTextureWidget DataSource="{Banner}" WidthSizePolicy="StretchToParent" HeightSizePolicy="StretchToParent" Brush="Flat.Tuple.Banner.Small" AdditionalArgs="@AdditionalArgs" ImageId="@Id" TextureProviderName="@TextureProviderName" IsDisabled="true" />
                      </Children>
                    </Widget>
                    <TextWidget IsVisible="@ShowLabel" WidthSizePolicy="StretchToParent" HeightSizePolicy="CoverChildren" HorizontalAlignment="Center" VerticalAlignment="Top" MarginTop="!NodeLabel.MarginTop" Brush="Clan.Leader.Text" Brush.TextHorizontalAlignment="Center" Text="@Name" />
                  </Children>
                </ButtonWidget>
              </ItemTemplate>
            </Widget>

          </Children>
        </Widget>

        <!-- Legend (issue #7): one clickable toggle row per active relation kind. Row = a
             line-style color swatch + label; a dimmed row (RowAlpha) means that kind's edges are
             hidden. Toggling re-filters the cached edges live in RelationsVM — no campaign
             re-query. Top-left, matching the design reference. -->
        <ListPanel DataSource="{Legend}" WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" HorizontalAlignment="Left" VerticalAlignment="Top" MarginLeft="30" MarginTop="24" StackLayout.LayoutMethod="VerticalTopToBottom">
          <ItemTemplate>
            <ButtonWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" MarginTop="4" AlphaFactor="@RowAlpha" Command.Click="ExecuteToggle">
              <Children>
                <ListPanel WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" StackLayout.LayoutMethod="HorizontalLeftToRight">
                  <Children>
                    <!-- Line-style swatch (a short colored bar, matching the reference legend) -->
                    <Widget WidthSizePolicy="Fixed" HeightSizePolicy="Fixed" SuggestedWidth="28" SuggestedHeight="4" VerticalAlignment="Center" Sprite="BlankWhiteSquare_9" Color="@SwatchColor" />
                    <TextWidget WidthSizePolicy="CoverChildren" HeightSizePolicy="CoverChildren" MarginLeft="12" VerticalAlignment="Center" Brush="Clan.Leader.Text" Text="@Label" />
                  </Children>
                </ListPanel>
              </Children>
            </ButtonWidget>
          </ItemTemplate>
        </ListPanel>

      </Children>
    </Widget>
  </Window>
</Prefab>
